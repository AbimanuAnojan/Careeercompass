# =========================
# Server Settings
# =========================
PORT=3000

# Comma-separated frontend origins allowed to call this API.
# Example: http://127.0.0.1:5500,http://localhost:5173,https://yourdomain.com
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# =========================
# Model Provider Settings
# =========================
GROK_API_KEY=gsk-xxxx
GROK_MODEL=grok-3-mini
# Optional: override provider endpoint
# GROK_BASE_URL=

# =========================
# Firebase Admin Settings
# Use ONE approach below
# =========================

# Optional (used by REST fallback auth path)
FIREBASE_WEB_API_KEY=AIza-your-firebase-web-api-key

# Option A (Recommended for local): point to service account file
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Option B: raw JSON string (useful in some CI/CD systems)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Option C: split fields (if you cannot store json file)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
